{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jira",
  "version": "0.1.3",
  "identifier": "com.jira.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Jira",
        "url": "index.html",
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://*.atlassian.net; connect-src *; img-src * data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Development",
    "shortDescription": "Jira desktop client",
    "longDescription": "Jira is a clean, focused desktop wrapper for Jira. No tabs. No distractions. Just Jira in its own window — fast, secure, and memory-efficient. Built with Tauri for native performance and minimal resource usage."
  }
}
