{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JDU - Jira Desktop Unofficial",
  "version": "0.1.3",
  "identifier": "com.jira-unofficial-desktop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "JDU - Jira Desktop Unofficial",
        "url": "index.html",
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://*.atlassian.net; connect-src *; img-src * data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
